# GitHub Activity Report — Configuration
# Copy this file to .env and fill in your values

# Required: GitHub Personal Access Token
# Scopes needed: read:org, repo (or public_repo for public repos only)
GITHUB_TOKEN=your_github_pat_here

# GitHub organization to report on
GITHUB_ORG=inkaviation

# Date range for the activity report (ISO 8601, inclusive)
SINCE_DATE=2026-04-06
UNTIL_DATE=2026-04-12
